[app]

title = Meme Car Game

package.name = memecargame

package.domain = org.shubhang

source.dir = .

source.include_exts = py,png,jpg,jpeg,mp3,wav,ogg,kv,atlas

version = 0.1

requirements = python3,kivy

orientation = landscape

fullscreen = 1

android.api = 34

android.minapi = 21

android.ndk = 25b

android.accept_sdk_license = True

android.archs = arm64-v8a

android.permissions = INTERNET


[buildozer]

log_level = 2

warn_on_root = 1
