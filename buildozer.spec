[app]
title = Meme Car Game
package.name = memecargame
package.domain = org.shubhang
source.dir = .
source.include_exts = py,png,jpg,mp3,wav
version = 0.1
requirements = python3,kivy
android.api = 34
android.minapi = 21
android.ndk = 25b
android.accept_sdk_license = True
orientation = landscape
fullscreen = 1
android.archs = arm64-v8a

[buildozer]
log_level = 2
warn_on_root = 1
